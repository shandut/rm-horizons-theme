{% doc %}
  @prompt
    "Hey, can you give me a countdown timer for Father's Day to make sure everything's shipped before Father's Day. it needs to be on brand colors, and I want it just below the hero image. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-countdown-timer-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    background-color: {{ block.settings.background_color }};
    text-align: center;
  }

  .ai-countdown-timer__heading-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
  }

  .ai-countdown-timer__subtext-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.subtext_spacing }}px;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.subtext_size }}px;
  }

  .ai-countdown-timer__units-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: {{ block.settings.unit_gap }}px;
    flex-wrap: wrap;
  }

  .ai-countdown-timer__unit-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: {{ block.settings.unit_min_width }}px;
  }

  .ai-countdown-timer__number-{{ ai_gen_id }} {
    font-size: {{ block.settings.number_size }}px;
    font-weight: 700;
    color: {{ block.settings.number_color }};
    line-height: 1;
    margin-bottom: 8px;
  }

  .ai-countdown-timer__label-{{ ai_gen_id }} {
    font-size: {{ block.settings.label_size }}px;
    color: {{ block.settings.label_color }};
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-countdown-timer__expired-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.subtext_size }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-countdown-timer__number-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.number_size }}px * 0.7);
    }

    .ai-countdown-timer__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }

    .ai-countdown-timer__unit-{{ ai_gen_id }} {
      min-width: calc({{ block.settings.unit_min_width }}px * 0.8);
    }
  }
{% endstyle %}

<countdown-timer-{{ ai_gen_id }}
  class="ai-countdown-timer-{{ ai_gen_id }}"
  data-target-date="{{ block.settings.target_date }}"
  data-target-time="{{ block.settings.target_time }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.heading != blank %}
    <h2 class="ai-countdown-timer__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
  {% endif %}

  {% if block.settings.subtext != blank %}
    <p class="ai-countdown-timer__subtext-{{ ai_gen_id }}">{{ block.settings.subtext }}</p>
  {% endif %}

  <div class="ai-countdown-timer__units-{{ ai_gen_id }}" data-countdown-display>
    <div class="ai-countdown-timer__unit-{{ ai_gen_id }}">
      <div class="ai-countdown-timer__number-{{ ai_gen_id }}" data-days>00</div>
      <div class="ai-countdown-timer__label-{{ ai_gen_id }}">Days</div>
    </div>
    <div class="ai-countdown-timer__unit-{{ ai_gen_id }}">
      <div class="ai-countdown-timer__number-{{ ai_gen_id }}" data-hours>00</div>
      <div class="ai-countdown-timer__label-{{ ai_gen_id }}">Hours</div>
    </div>
    <div class="ai-countdown-timer__unit-{{ ai_gen_id }}">
      <div class="ai-countdown-timer__number-{{ ai_gen_id }}" data-minutes>00</div>
      <div class="ai-countdown-timer__label-{{ ai_gen_id }}">Minutes</div>
    </div>
    <div class="ai-countdown-timer__unit-{{ ai_gen_id }}">
      <div class="ai-countdown-timer__number-{{ ai_gen_id }}" data-seconds>00</div>
      <div class="ai-countdown-timer__label-{{ ai_gen_id }}">Seconds</div>
    </div>
  </div>

  <div class="ai-countdown-timer__expired-{{ ai_gen_id }}" data-expired-message style="display: none;">
    {{ block.settings.expired_message }}
  </div>
</countdown-timer-{{ ai_gen_id }}>

<script>
  (function() {
    class CountdownTimer{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.targetDate = this.dataset.targetDate;
        this.targetTime = this.dataset.targetTime;
        this.interval = null;
      }

      connectedCallback() {
        if (!this.targetDate) {
          return;
        }

        this.daysElement = this.querySelector('[data-days]');
        this.hoursElement = this.querySelector('[data-hours]');
        this.minutesElement = this.querySelector('[data-minutes]');
        this.secondsElement = this.querySelector('[data-seconds]');
        this.countdownDisplay = this.querySelector('[data-countdown-display]');
        this.expiredMessage = this.querySelector('[data-expired-message]');

        this.startCountdown();
      }

      disconnectedCallback() {
        if (this.interval) {
          clearInterval(this.interval);
        }
      }

      startCountdown() {
        this.updateCountdown();
        this.interval = setInterval(() => {
          this.updateCountdown();
        }, 1000);
      }

      updateCountdown() {
        const targetDateTime = this.targetTime 
          ? new Date(this.targetDate + 'T' + this.targetTime)
          : new Date(this.targetDate + 'T23:59:59');
        
        const now = new Date().getTime();
        const distance = targetDateTime.getTime() - now;

        if (distance < 0) {
          clearInterval(this.interval);
          this.countdownDisplay.style.display = 'none';
          this.expiredMessage.style.display = 'block';
          return;
        }

        const days = Math.floor(distance / (1000 * 60 * 60 * 24));
        const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((distance % (1000 * 60)) / 1000);

        this.daysElement.textContent = String(days).padStart(2, '0');
        this.hoursElement.textContent = String(hours).padStart(2, '0');
        this.minutesElement.textContent = String(minutes).padStart(2, '0');
        this.secondsElement.textContent = String(seconds).padStart(2, '0');
      }
    }

    customElements.define('countdown-timer-{{ ai_gen_id }}', CountdownTimer{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Father's Day countdown",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",

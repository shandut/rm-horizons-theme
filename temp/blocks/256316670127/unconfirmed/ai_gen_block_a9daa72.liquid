      "id": "heading_color",
      "label": "Heading",
      "default": "#1f1007"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#1f1007"
    },
    {
      "type": "color",
      "id": "number_color",

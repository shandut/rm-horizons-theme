{% doc %}
  @prompt
    can you add a count down timer like this screenshot  but on brand for RM williams colours schemes, also give the user options to toggle with 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-countdown-timer-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    text-align: center;
  }

  .ai-countdown-timer__heading-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 700;
    letter-spacing: 0.5px;
  }

  .ai-countdown-timer__subheading-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.subheading_spacing }}px;
    color: {{ block.settings.subheading_color }};
    font-size: {{ block.settings.subheading_size }}px;
    opacity: 0.9;
  }

  .ai-countdown-timer__display-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: {{ block.settings.unit_gap }}px;
    flex-wrap: wrap;
  }

  .ai-countdown-timer__unit-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: {{ block.settings.unit_width }}px;
  }

  .ai-countdown-timer__value-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    width: {{ block.settings.unit_width }}px;
    height: {{ block.settings.unit_height }}px;
    background-color: {{ block.settings.unit_background }};
    color: {{ block.settings.unit_text_color }};
    font-size: {{ block.settings.number_size }}px;
    font-weight: 700;
    border-radius: {{ block.settings.unit_border_radius }}px;
    border: {{ block.settings.unit_border_width }}px solid {{ block.settings.unit_border_color }};
    box-shadow: 0 2px 8px rgba(31, 16, 7, 0.1);
  }

  .ai-countdown-timer__label-{{ ai_gen_id }} {
    margin-top: 8px;
    color: {{ block.settings.label_color }};
    font-size: {{ block.settings.label_size }}px;
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: 500;
  }

  .ai-countdown-timer__separator-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    color: {{ block.settings.separator_color }};
    font-size: {{ block.settings.number_size }}px;
    font-weight: 700;
    padding: 0 4px;
    margin-bottom: 32px;
  }

  .ai-countdown-timer__expired-{{ ai_gen_id }} {
    color: {{ block.settings.expired_text_color }};
    font-size: {{ block.settings.expired_text_size }}px;
    font-weight: 600;
    padding: 20px;
  }

  @media screen and (max-width: 749px) {
    .ai-countdown-timer__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }

    .ai-countdown-timer__subheading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subheading_size }}px * 0.9);
    }

    .ai-countdown-timer__unit-{{ ai_gen_id }} {
      min-width: calc({{ block.settings.unit_width }}px * 0.8);
    }

    .ai-countdown-timer__value-{{ ai_gen_id }} {
      width: calc({{ block.settings.unit_width }}px * 0.8);
      height: calc({{ block.settings.unit_height }}px * 0.8);
      font-size: calc({{ block.settings.number_size }}px * 0.8);
    }

    .ai-countdown-timer__label-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.label_size }}px * 0.9);
    }

    .ai-countdown-timer__separator-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.number_size }}px * 0.8);
    }
  }
{% endstyle %}

<countdown-timer-{{ ai_gen_id }}
  class="ai-countdown-timer-{{ ai_gen_id }}"
  data-end-date="{{ block.settings.end_date }}"
  data-end-time="{{ block.settings.end_time }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.show_heading and block.settings.heading != blank %}
    <h2 class="ai-countdown-timer__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
  {% endif %}

  {% if block.settings.show_subheading and block.settings.subheading != blank %}
    <p class="ai-countdown-timer__subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
  {% endif %}

  <div class="ai-countdown-timer__display-{{ ai_gen_id }}" data-timer-display>
    {% if block.settings.show_days %}
      <div class="ai-countdown-timer__unit-{{ ai_gen_id }}">
        <div class="ai-countdown-timer__value-{{ ai_gen_id }}" data-days>00</div>
        <div class="ai-countdown-timer__label-{{ ai_gen_id }}">Days</div>
      </div>
      {% if block.settings.show_separator %}
        <div class="ai-countdown-timer__separator-{{ ai_gen_id }}">:</div>
      {% endif %}
    {% endif %}

    {% if block.settings.show_hours %}
      <div class="ai-countdown-timer__unit-{{ ai_gen_id }}">
        <div class="ai-countdown-timer__value-{{ ai_gen_id }}" data-hours>00</div>
        <div class="ai-countdown-timer__label-{{ ai_gen_id }}">Hours</div>
      </div>
      {% if block.settings.show_separator %}
        <div class="ai-countdown-timer__separator-{{ ai_gen_id }}">:</div>
      {% endif %}
    {% endif %}

    {% if block.settings.show_minutes %}
      <div class="ai-countdown-timer__unit-{{ ai_gen_id }}">
        <div class="ai-countdown-timer__value-{{ ai_gen_id }}" data-minutes>00</div>
        <div class="ai-countdown-timer__label-{{ ai_gen_id }}">Minutes</div>
      </div>
      {% if block.settings.show_separator %}
        <div class="ai-countdown-timer__separator-{{ ai_gen_id }}">:</div>
      {% endif %}
    {% endif %}

    {% if block.settings.show_seconds %}
      <div class="ai-countdown-timer__unit-{{ ai_gen_id }}">
        <div class="ai-countdown-timer__value-{{ ai_gen_id }}" data-seconds>00</div>
        <div class="ai-countdown-timer__label-{{ ai_gen_id }}">Seconds</div>
      </div>
    {% endif %}
  </div>

  <div class="ai-countdown-timer__expired-{{ ai_gen_id }}" data-expired-message style="display: none;">
    {{ block.settings.expired_message }}
  </div>
</countdown-timer-{{ ai_gen_id }}>

<script>
  (function() {
    class CountdownTimer{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.endDate = this.dataset.endDate;
        this.endTime = this.dataset.endTime;
        this.timerDisplay = this.querySelector('[data-timer-display]');
        this.expiredMessage = this.querySelector('[data-expired-message]');
        this.daysEl = this.querySelector('[data-days]');
        this.hoursEl = this.querySelector('[data-hours]');
        this.minutesEl = this.querySelector('[data-minutes]');
        this.secondsEl = this.querySelector('[data-seconds]');
        this.interval = null;
      }

      connectedCallback() {
        if (this.endDate) {
          this.startCountdown();
        }
      }

      disconnectedCallback() {
        if (this.interval) {
          clearInterval(this.interval);
        }
      }

      startCountdown() {
        this.updateCountdown();
        this.interval = setInterval(() => {
          this.updateCountdown();
        }, 1000);
      }

      updateCountdown() {
        const endDateTime = this.getEndDateTime();
        const now = new Date().getTime();
        const distance = endDateTime - now;

        if (distance < 0) {
          clearInterval(this.interval);
          this.showExpiredMessage();
          return;
        }

        const days = Math.floor(distance / (1000 * 60 * 60 * 24));
        const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((distance % (1000 * 60)) / 1000);

        if (this.daysEl) this.daysEl.textContent = this.padZero(days);
        if (this.hoursEl) this.hoursEl.textContent = this.padZero(hours);
        if (this.minutesEl) this.minutesEl.textContent = this.padZero(minutes);
        if (this.secondsEl) this.secondsEl.textContent = this.padZero(seconds);
      }

      getEndDateTime() {
        let dateTimeString = this.endDate;
        if (this.endTime) {
          dateTimeString += 'T' + this.endTime;
        } else {
          dateTimeString += 'T23:59:59';
        }
        return new Date(dateTimeString).getTime();
      }

      padZero(num) {
        return num.toString().padStart(2, '0');
      }

      showExpiredMessage() {
        if (this.timerDisplay) {
          this.timerDisplay.style.display = 'none';
        }
        if (this.expiredMessage) {
          this.expiredMessage.style.display = 'block';
        }
      }
    }

    customElements.define('countdown-timer-{{ ai_gen_id }}', CountdownTimer{{ ai_gen_id }});
  })();
</script>


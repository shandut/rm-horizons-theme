{% doc %}
  @prompt
    Can you generate the countdown timer as a section on this page with the RM Williams branding and layouts and styles please? 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-countdown-timer-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    background-color: {{ block.settings.background_color }};
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-countdown-timer-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-countdown-timer-heading-{{ ai_gen_id }} {
    font-family: var(--font-heading-family);
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.spacing_below_heading }}px;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .ai-countdown-timer-subheading-{{ ai_gen_id }} {
    font-family: var(--font-body-family);
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.subheading_color }};
    margin: 0 0 {{ block.settings.spacing_below_subheading }}px;
    line-height: 1.6;
  }

  .ai-countdown-timer-display-{{ ai_gen_id }} {
    display: flex;
    justify-content: {{ block.settings.text_alignment }};
    gap: {{ block.settings.timer_gap }}px;
    flex-wrap: wrap;
  }

  .ai-countdown-timer-unit-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: {{ block.settings.unit_width }}px;
  }

  .ai-countdown-timer-value-{{ ai_gen_id }} {
    font-family: var(--font-heading-family);
    font-size: {{ block.settings.number_size }}px;
    color: {{ block.settings.number_color }};
    font-weight: 700;
    line-height: 1;
    margin-bottom: 8px;
    letter-spacing: -0.02em;
  }

  .ai-countdown-timer-label-{{ ai_gen_id }} {
    font-family: var(--font-body-family);
    font-size: {{ block.settings.label_size }}px;
    color: {{ block.settings.label_color }};
    text-transform: {{ block.settings.label_text_transform }};
    letter-spacing: 0.05em;
  }

  .ai-countdown-timer-expired-{{ ai_gen_id }} {
    font-family: var(--font-heading-family);
    font-size: {{ block.settings.expired_message_size }}px;
    color: {{ block.settings.expired_message_color }};
    font-weight: 700;
    display: none;
  }

  .ai-countdown-timer-expired-{{ ai_gen_id }}.active {
    display: block;
  }

  .ai-countdown-timer-display-{{ ai_gen_id }}.hidden {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .ai-countdown-timer-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-countdown-timer-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.7);
    }

    .ai-countdown-timer-subheading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subheading_size }}px * 0.9);
    }

    .ai-countdown-timer-value-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.number_size }}px * 0.7);
    }

    .ai-countdown-timer-label-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.label_size }}px * 0.9);
    }

    .ai-countdown-timer-unit-{{ ai_gen_id }} {
      min-width: calc({{ block.settings.unit_width }}px * 0.8);
    }

    .ai-countdown-timer-display-{{ ai_gen_id }} {
      gap: calc({{ block.settings.timer_gap }}px * 0.7);
    }
  }
{% endstyle %}

<countdown-timer-{{ ai_gen_id }}
  class="ai-countdown-timer-{{ ai_gen_id }}"
  data-end-date="{{ block.settings.end_date }}"
  data-end-time="{{ block.settings.end_time }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-countdown-timer-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-countdown-timer-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    {% if block.settings.subheading != blank %}
      <p class="ai-countdown-timer-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
    {% endif %}

    <div class="ai-countdown-timer-display-{{ ai_gen_id }}">
      {% if block.settings.show_days %}
        <div class="ai-countdown-timer-unit-{{ ai_gen_id }}">
          <div class="ai-countdown-timer-value-{{ ai_gen_id }}" data-unit="days">00</div>
          <div class="ai-countdown-timer-label-{{ ai_gen_id }}">{{ block.settings.days_label }}</div>
        </div>
      {% endif %}

      {% if block.settings.show_hours %}
        <div class="ai-countdown-timer-unit-{{ ai_gen_id }}">
          <div class="ai-countdown-timer-value-{{ ai_gen_id }}" data-unit="hours">00</div>
          <div class="ai-countdown-timer-label-{{ ai_gen_id }}">{{ block.settings.hours_label }}</div>
        </div>
      {% endif %}

      {% if block.settings.show_minutes %}
        <div class="ai-countdown-timer-unit-{{ ai_gen_id }}">
          <div class="ai-countdown-timer-value-{{ ai_gen_id }}" data-unit="minutes">00</div>
          <div class="ai-countdown-timer-label-{{ ai_gen_id }}">{{ block.settings.minutes_label }}</div>
        </div>
      {% endif %}

      {% if block.settings.show_seconds %}
        <div class="ai-countdown-timer-unit-{{ ai_gen_id }}">
          <div class="ai-countdown-timer-value-{{ ai_gen_id }}" data-unit="seconds">00</div>
          <div class="ai-countdown-timer-label-{{ ai_gen_id }}">{{ block.settings.seconds_label }}</div>
        </div>
      {% endif %}
    </div>

    {% if block.settings.expired_message != blank %}
      <div class="ai-countdown-timer-expired-{{ ai_gen_id }}">{{ block.settings.expired_message }}</div>
    {% endif %}
  </div>
</countdown-timer-{{ ai_gen_id }}>

<script>
  (function() {
    class CountdownTimer{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.endDate = this.dataset.endDate;
        this.endTime = this.dataset.endTime;
        this.interval = null;
      }

      connectedCallback() {
        if (!this.endDate || !this.endTime) {
          return;
        }

        this.display = this.querySelector('.ai-countdown-timer-display-{{ ai_gen_id }}');
        this.expiredMessage = this.querySelector('.ai-countdown-timer-expired-{{ ai_gen_id }}');
        this.daysElement = this.querySelector('[data-unit="days"]');
        this.hoursElement = this.querySelector('[data-unit="hours"]');
        this.minutesElement = this.querySelector('[data-unit="minutes"]');
        this.secondsElement = this.querySelector('[data-unit="seconds"]');

        this.startCountdown();
      }

      disconnectedCallback() {
        if (this.interval) {
          clearInterval(this.interval);
        }
      }

      startCountdown() {
        const targetDateTime = new Date(this.endDate + 'T' + this.endTime).getTime();

        const updateTimer = () => {
          const now = new Date().getTime();
          const distance = targetDateTime - now;

          if (distance < 0) {
            this.handleExpired();
            return;
          }

          const days = Math.floor(distance / (1000 * 60 * 60 * 24));
          const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
          const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
          const seconds = Math.floor((distance % (1000 * 60)) / 1000);

          if (this.daysElement) {
            this.daysElement.textContent = String(days).padStart(2, '0');
          }
          if (this.hoursElement) {
            this.hoursElement.textContent = String(hours).padStart(2, '0');
          }
          if (this.minutesElement) {
            this.minutesElement.textContent = String(minutes).padStart(2, '0');
          }
          if (this.secondsElement) {
            this.secondsElement.textContent = String(seconds).padStart(2, '0');
          }
        };

        updateTimer();
        this.interval = setInterval(updateTimer, 1000);
      }

      handleExpired() {
        if (this.interval) {
          clearInterval(this.interval);
        }
        if (this.display) {
          this.display.classList.add('hidden');
        }
        if (this.expiredMessage) {
          this.expiredMessage.classList.add('active');
        }
      }
    }

    customElements.define('countdown-timer-{{ ai_gen_id }}', CountdownTimer{{ ai_gen_id }});
  })();
</script>


{% doc %}
  @prompt
    Can you recreate this section in RM Williams branding? and as the Father's Day free gift wrapping service. , Can we add in a centering button for this banner? And also I'd like to add a background image. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-gift-wrap-service-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    border-radius: {{ block.settings.border_radius }}px;
    position: relative;
    overflow: hidden;
  }

  .ai-gift-wrap-bg-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: {{ block.settings.background_image_opacity | divided_by: 100.0 }};
    z-index: 0;
  }

  .ai-gift-wrap-container-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.content_gap }}px;
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
    {% if block.settings.content_alignment == 'center' %}
      flex-direction: column;
      text-align: center;
    {% elsif block.settings.content_alignment == 'right' %}
      flex-direction: row-reverse;
    {% endif %}
  }

  .ai-gift-wrap-icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-gift-wrap-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    fill: none;
    stroke: {{ block.settings.icon_color }};
    stroke-width: {{ block.settings.icon_stroke_width }};
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .ai-gift-wrap-content-{{ ai_gen_id }} {
    {% if block.settings.content_alignment == 'center' %}
      flex-grow: 0;
    {% else %}
      flex-grow: 1;
    {% endif %}
  }

  .ai-gift-wrap-heading-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.heading_spacing }}px 0;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    font-weight: {{ block.settings.heading_weight }};
    line-height: 1.2;
  }

  .ai-gift-wrap-text-{{ ai_gen_id }} {
    margin: 0;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.5;
  }

  .ai-gift-wrap-text-{{ ai_gen_id }} p {
    margin: 0;
  }

  .ai-gift-wrap-cta-{{ ai_gen_id }} {
    flex-shrink: 0;
  }

  .ai-gift-wrap-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    text-decoration: none;
    text-align: center;
    cursor: pointer;
    transition: all 0.3s ease;
    white-space: nowrap;
  }

  .ai-gift-wrap-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-gift-wrap-container-{{ ai_gen_id }} {
      flex-direction: column;
      text-align: center;
      gap: {{ block.settings.mobile_gap }}px;
    }

    .ai-gift-wrap-icon-{{ ai_gen_id }} {
      width: {{ block.settings.mobile_icon_size }}px;
      height: {{ block.settings.mobile_icon_size }}px;
    }

    .ai-gift-wrap-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_heading_size }}px;
    }

    .ai-gift-wrap-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_text_size }}px;
    }

    .ai-gift-wrap-button-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<div class="ai-gift-wrap-service-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.background_image %}
    <img
      src="{{ block.settings.background_image | image_url: width: 2000 }}"
      alt="{{ block.settings.background_image.alt | escape }}"
      loading="lazy"
      width="{{ block.settings.background_image.width }}"
      height="{{ block.settings.background_image.height }}"
      class="ai-gift-wrap-bg-image-{{ ai_gen_id }}"
    >
  {% endif %}

  <div class="ai-gift-wrap-container-{{ ai_gen_id }}">
    {% if block.settings.show_icon %}
      <div class="ai-gift-wrap-icon-{{ ai_gen_id }}">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
          <path d="M20 7h-1.209A4.92 4.92 0 0 0 19 5.5C19 3.57 17.43 2 15.5 2c-1.58 0-2.903 1.06-3.337 2.5h-.326C11.403 3.06 10.08 2 8.5 2 6.57 2 5 3.57 5 5.5c0 .596.079 1.089.209 1.5H4c-1.103 0-2 .897-2 2v2c0 1.103.897 2 2 2v7c0 1.103.897 2 2 2h12c1.103 0 2-.897 2-2v-7c1.103 0 2-.897 2-2V9c0-1.103-.897-2-2-2zM8.5 4C9.327 4 10 4.673 10 5.5S9.327 7 8.5 7 7 6.327 7 5.5 7.673 4 8.5 4zm7 0c.827 0 1.5.673 1.5 1.5S16.327 7 15.5 7 14 6.327 14 5.5s.673-1.5 1.5-1.5zM4 9h7v2H4V9zm0 11v-7h7v7H4zm9 0v-7h7v7h-7zm7-9h-7V9h7v2z"/>
        </svg>
      </div>
    {% endif %}

    <div class="ai-gift-wrap-content-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h3 class="ai-gift-wrap-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h3>
      {% endif %}
      {% if block.settings.text != blank %}
        <div class="ai-gift-wrap-text-{{ ai_gen_id }}">{{ block.settings.text }}</div>
      {% endif %}
    </div>

    {% if block.settings.show_button and block.settings.button_text != blank %}
      <div class="ai-gift-wrap-cta-{{ ai_gen_id }}">
        <a href="{{ block.settings.button_link }}" class="ai-gift-wrap-button-{{ ai_gen_id }}">
          {{ block.settings.button_text }}
        </a>
      </div>
    {% endif %}
  </div>
</div>


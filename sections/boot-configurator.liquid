{%- comment -%} Three.js importmap — load from CDN {%- endcomment -%}
<script type="importmap">
{
  "imports": {
    "three": "https://esm.sh/three@0.172.0",
    "three/addons/": "https://esm.sh/three@0.172.0/examples/jsm/"

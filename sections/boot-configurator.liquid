{%- comment -%}
  3D Boot Configurator (v2) — Three.js WebGL configurator
  Loads a real GLB model and applies real-time colour changes.
  Liquid is "dumb" — it renders the DOM shell and embeds data.
  JavaScript owns the entire configurator experience.

  Path A: Colour-only configurator (single GLB, material swaps)
  Path B (future): Shape-swappable sub-meshes for toe/heel/sole variants
{%- endcomment -%}

{% liquid
  assign product = product
  assign variant = product.selected_or_first_available_variant
%}

<div
  id="BootConfigurator3D-{{ section.id }}"
  class="boot-configurator"
  data-section-id="{{ section.id }}"
  data-product-id="{{ product.id }}"
  data-base-variant-id="{{ variant.id }}"
  data-money-format="{{ shop.money_format | escape }}"
  data-cart-add-url="{{ routes.cart_add_url }}"
  data-model-url="https://cdn.shopify.com/3d/models/98599c409d81cbb7/RMWilliams-boot-3dimage.glb"
>
  {%- comment -%} 3D Viewer {%- endcomment -%}
  <div class="boot-configurator__viewer">
    <canvas class="boot-configurator__canvas" aria-label="3D boot configurator preview"></canvas>
    <div class="boot-configurator__loader" aria-live="polite">
      <div class="boot-configurator__spinner"></div>
      <span class="boot-configurator__loader-text">Loading 3D preview&hellip;</span>
      <div class="boot-configurator__progress-bar">
        <div class="boot-configurator__progress-fill"></div>
      </div>
    </div>
    <noscript>
      <img src="{{ 'configurator-body.png' | asset_url }}" alt="Boot preview" class="boot-configurator__fallback">
    </noscript>
  </div>

  {%- comment -%} Configuration Panel — populated entirely by JS {%- endcomment -%}
  <div class="boot-configurator__panel">
    <div class="boot-configurator__header">
      <h1 class="boot-configurator__title">Design Your Boot</h1>
      <p class="boot-configurator__subtitle">3D Made to Order Configurator</p>
    </div>
    <div class="boot-configurator__phases"></div>
    <div class="boot-configurator__steps"></div>
    <div class="boot-configurator__summary"></div>
    <div class="boot-configurator__price"></div>
    <div class="boot-configurator__actions">
      <button type="button" class="boot-configurator__btn boot-configurator__btn--back" hidden>Back</button>
      <button type="button" class="boot-configurator__btn boot-configurator__btn--next">Next</button>
      <button type="button" class="boot-configurator__btn boot-configurator__btn--add" hidden>Add to Cart</button>
    </div>
    <div class="boot-configurator__live-region visually-hidden" role="status"></div>
  </div>


{{ 'boot-configurator.css' | asset_url | stylesheet_tag }}
<script src="{{ 'boot-configurator.bundle.js' | asset_url }}" type="module"></script>

{% schema %}
{
  "name": "3D Boot Configurator",
  "tag": "section",
  "class": "boot-configurator-section",
  "settings": [],
  "templates": ["product"],
  "presets": [
    {
      "name": "3D Boot Configurator"
    }
  ]
}
{% endschema %}

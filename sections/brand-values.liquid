{%- comment -%}
  Brand Story / Values Grid — up to 4 columns, each with
  an image, heading, and body text.  Staggered fade-up on scroll.
{%- endcomment -%}

{% liquid
  assign value_blocks = section.blocks | where: 'type', 'value'
  assign col_count = value_blocks.size | at_most: 4
%}

<div
  class="brand-values"
  id="BrandValues-{{ section.id }}"
  style="
    --bv-columns: {{ col_count }};
    --bv-gap: {{ section.settings.column_gap | default: 32 }}px;
  "
>
  {% if section.settings.heading != blank %}
    <div class="brand-values__header">
      <h2 class="brand-values__title">{{ section.settings.heading }}</h2>
    </div>
  {% endif %}

  {% if section.settings.subheading != blank %}
    <p class="brand-values__subheading">{{ section.settings.subheading }}</p>
  {% endif %}

  <div class="brand-values__grid">
    {% for block in value_blocks %}
      {% assign delay = forloop.index0 | times: 150 %}
      <div
        class="brand-values__item"
        data-scroll-reveal
        data-scroll-delay="{{ delay }}"
        {{ block.shopify_attributes }}
      >
        {% if block.settings.image != blank %}
          <div class="brand-values__image">
            {{
              block.settings.image
              | image_url: width: 800
              | image_tag:
                widths: '300, 400, 600, 800',
                sizes: '(min-width: 990px) 33vw, (min-width: 750px) 50vw, 100vw',
                loading: 'lazy',
                alt: block.settings.image.alt | default: block.settings.heading
            }}
          </div>
        {% endif %}

        {% if block.settings.heading != blank %}
          <h3 class="brand-values__item-heading">{{ block.settings.heading }}</h3>
        {% endif %}

        {% if block.settings.body != blank %}
          <div class="brand-values__item-body">{{ block.settings.body }}</div>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</div>

<script src="{{ 'scroll-reveal.js' | asset_url }}" defer="defer"></script>

{% stylesheet %}
  .brand-values {
    padding-block: clamp(2.5rem, 5vw, 4.5rem);
    padding-inline: clamp(1rem, 2.5vw, 2.5rem);
    max-width: var(--normal-page-width, 120rem);
    margin: 0 auto;
  }

  .brand-values__header {
    text-align: center;
    margin-block-end: 0.5rem;
  }

  .brand-values__title {
    font-family: var(--font-heading--family);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: var(--font-heading--weight, 400);
    line-height: 1.15;
    letter-spacing: -0.01em;
    color: var(--color-foreground-heading, var(--color-foreground));
    margin: 0;
  }

  .brand-values__subheading {
    text-align: center;
    font-family: var(--font-body--family);
    font-size: clamp(0.875rem, 1.2vw, 1rem);
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text, 0.7));
    margin: 0 0 clamp(1.5rem, 3vw, 2.5rem);
    max-width: 48ch;
    margin-inline: auto;
  }

  /* ---- Grid ---- */
  .brand-values__grid {
    display: grid;
    grid-template-columns: repeat(var(--bv-columns, 3), 1fr);
    gap: var(--bv-gap, 2rem);
  }

  /* ---- Item ---- */
  .brand-values__item {
    text-align: center;
  }

  /* Scroll-reveal base state */
  [data-scroll-reveal] {
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity 0.6s var(--animation-timing-hover, cubic-bezier(0.25, 0.46, 0.45, 0.94)),
      transform 0.6s var(--animation-timing-hover, cubic-bezier(0.25, 0.46, 0.45, 0.94));
  }

  [data-scroll-reveal].is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    [data-scroll-reveal] {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  .brand-values__image {
    overflow: hidden;
    border-radius: var(--card-corner-radius, 4px);
    margin-block-end: 1rem;
  }

  .brand-values__image img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.45s var(--animation-timing-hover, ease);
  }

  .brand-values__item:hover .brand-values__image img {
    transform: scale(1.04);
  }

  .brand-values__item-heading {
    font-family: var(--font-heading--family);
    font-size: clamp(1.1rem, 1.8vw, 1.375rem);
    font-weight: var(--font-heading--weight, 400);
    color: var(--color-foreground-heading, var(--color-foreground));
    line-height: 1.2;
    margin: 0 0 0.5rem;
  }

  .brand-values__item-body {
    font-family: var(--font-body--family);
    font-size: clamp(0.8rem, 1vw, 0.9375rem);
    color: var(--color-foreground);
    line-height: 1.6;
  }

  .brand-values__item-body p {
    margin: 0;
  }

  /* ---- Responsive ---- */
  @media screen and (max-width: 749px) {
    .brand-values__grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  @media screen and (min-width: 750px) and (max-width: 989px) {
    .brand-values__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.brand_values",
  "tag": "section",
  "class": "brand-values-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Values"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "range",
      "id": "column_gap",
      "label": "Column gap",
      "min": 8,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "value",
      "name": "Value",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Craftsmanship"
        },
        {
          "type": "richtext",
          "id": "body",
          "label": "Description",
          "default": "<p>Every piece is crafted with care, using techniques refined over generations.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brand values",
      "category": "Content",
      "blocks": [
        {
          "type": "value",
          "settings": {
            "heading": "Craftsmanship",
            "body": "<p>Every piece is crafted with care, using techniques refined over generations.</p>"
          }
        },
        {
          "type": "value",
          "settings": {
            "heading": "Heritage",
            "body": "<p>A story that began in the Australian outback and now spans the globe.</p>"
          }
        },
        {
          "type": "value",
          "settings": {
            "heading": "Quality",
            "body": "<p>We source only the finest materials to create products that last a lifetime.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}

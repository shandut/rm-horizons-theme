{% liquid
  assign slide_blocks = section.blocks | where: 'type', 'slide'
  assign slide_count = slide_blocks.size
  assign autoplay_speed = section.settings.autoplay_speed | default: 5
%}

<video-hero-component
  class="video-hero-slideshow section--full-width"
  id="VideoHero-{{ section.id }}"
  data-autoplay-speed="{{ autoplay_speed }}"
  data-slide-count="{{ slide_count }}"
  role="region"
  aria-roledescription="carousel"
  aria-label="Hero slideshow"
  on:mouseenter="/onMouseEnter"
  on:mouseleave="/onMouseLeave"
  on:keydown="/handleKeydown"
>
  {%- comment -%} Overlay — dual gradient: dark from top (for menu legibility) and bottom (for text legibility) {%- endcomment -%}
  {% if section.settings.show_overlay %}
    <div
      class="video-hero-slideshow__overlay"
      style="background:
        linear-gradient(to bottom, {{ section.settings.overlay_color | color_modify: 'alpha', 0.45 }} 0%, {{ section.settings.overlay_color | color_modify: 'alpha', 0 }} 20%),
        linear-gradient({{ section.settings.overlay_direction }}, {{ section.settings.overlay_color }}, {{ section.settings.overlay_color | color_modify: 'alpha', 0 }});"
    ></div>
  {% endif %}

  {%- comment -%} Slides — each with its own video background {%- endcomment -%}
  {% if slide_count > 0 %}
    <div class="video-hero-slideshow__slides">
      {% for block in slide_blocks %}
        {%- liquid
          assign slide_video = block.settings.video_url
          assign slide_mobile_video = block.settings.mobile_video_url | default: slide_video
        -%}
        <div
          class="video-hero-slideshow__slide{% if forloop.first %} video-hero-slideshow__slide--active{% endif %}"
          ref="slides[]"
          data-slide-index="{{ forloop.index0 }}"
          role="group"
          aria-roledescription="slide"
          aria-label="Slide {{ forloop.index }} of {{ slide_count }}"
          {{ block.shopify_attributes }}
        >
          {%- comment -%} Per-slide video background {%- endcomment -%}
          <div class="video-hero-slideshow__media">
            {% if slide_video != blank %}
              <video
                class="video-hero-slideshow__video video-hero-slideshow__video--desktop"
                src="{{ slide_video }}"
                playsinline
                muted
                {% if forloop.first %}autoplay{% endif %}
                loop
                preload="{% if forloop.first %}auto{% else %}metadata{% endif %}"
                {% if forloop.first %}fetchpriority="high"{% endif %}
              ></video>
              {% if slide_mobile_video != slide_video %}
                <video
                  class="video-hero-slideshow__video video-hero-slideshow__video--mobile"
                  src="{{ slide_mobile_video }}"
                  playsinline
                  muted
                  {% if forloop.first %}autoplay{% endif %}
                  loop
                  preload="{% if forloop.first %}auto{% else %}metadata{% endif %}"
                  {% if forloop.first %}fetchpriority="high"{% endif %}
                ></video>
              {% endif %}
            {% else %}
              <div class="video-hero-slideshow__placeholder">
                {{ 'hero-apparel-1' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>

          {%- comment -%} Slide text content {%- endcomment -%}
          <div class="video-hero-slideshow__slide-content">
            <div class="video-hero-slideshow__slide-inner" style="text-align: {{ block.settings.text_alignment | default: 'center' }};">
              {% if block.settings.subheading != blank %}
                <p class="video-hero-slideshow__subheading">
                  {{ block.settings.subheading }}
                </p>
              {% endif %}

              {% if block.settings.heading != blank %}
                <h2 class="video-hero-slideshow__heading">
                  {{ block.settings.heading }}
                </h2>
              {% endif %}

              <div class="video-hero-slideshow__buttons">
                {% if block.settings.button_label_1 != blank %}
                  <a
                    href="{{ block.settings.button_link_1 | default: '#' }}"
                    class="video-hero-slideshow__button video-hero-slideshow__button--{{ block.settings.button_style_1 | default: 'primary' }}"
                  >
                    {{ block.settings.button_label_1 }}
                  </a>
                {% endif %}

                {% if block.settings.button_label_2 != blank %}
                  <a
                    href="{{ block.settings.button_link_2 | default: '#' }}"
                    class="video-hero-slideshow__button video-hero-slideshow__button--{{ block.settings.button_style_2 | default: 'secondary' }}"
                  >
                    {{ block.settings.button_label_2 }}
                  </a>
                {% endif %}
              </div>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>

    {%- comment -%} Bottom Controls: Prev Arrow | Dots | Pause | Next Arrow {%- endcomment -%}
    {% if slide_count > 1 %}
      <div class="video-hero-slideshow__controls">
        <button
          class="video-hero-slideshow__arrow video-hero-slideshow__arrow--prev"
          ref="prevBtn"
          aria-label="Previous slide"
          on:click="/prevSlide"
        >
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M13 16L7 10L13 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>

        <div class="video-hero-slideshow__dots" role="tablist" aria-label="Slide navigation">
          {% for block in slide_blocks %}
            <button
              class="video-hero-slideshow__dot{% if forloop.first %} video-hero-slideshow__dot--active{% endif %}"
              ref="dots[]"
              data-slide-index="{{ forloop.index0 }}"
              role="tab"
              aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
              aria-label="Go to slide {{ forloop.index }}"
              on:click="/goToSlideFromDot"
            >
              <span class="video-hero-slideshow__dot-progress"></span>
            </button>
          {% endfor %}
        </div>

        <button
          class="video-hero-slideshow__arrow video-hero-slideshow__arrow--next"
          ref="nextBtn"
          aria-label="Next slide"
          on:click="/nextSlide"
        >
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M7 4L13 10L7 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>

      {%- comment -%} Live region for screen reader announcements {%- endcomment -%}
      <div ref="liveRegion" class="visually-hidden" aria-live="polite" aria-atomic="true">
        Slide 1 of {{ slide_count }}
      </div>
    {% endif %}
  {% endif %}

</video-hero-component>

<script src="{{ 'video-hero-slideshow.js' | asset_url }}" type="module"></script>

{% stylesheet %}
  .video-hero-slideshow {
    position: relative;
    width: 100%;
    height: 100svh;
    min-height: 500px;
    max-height: 1000px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  /* Overlay (shared, sits above all slides) */
  .video-hero-slideshow__overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
  }

  /* Slides container */
  .video-hero-slideshow__slides {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  /* Individual slide — full bleed, stacked */
  .video-hero-slideshow__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.8s ease, visibility 0.8s ease;
    pointer-events: none;
  }

  .video-hero-slideshow__slide--active {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    z-index: 1;
  }

  /* Per-slide video background */
  .video-hero-slideshow__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .video-hero-slideshow__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .video-hero-slideshow__video--mobile {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .video-hero-slideshow__video--desktop {
      display: none;
    }
    .video-hero-slideshow__video--mobile {
      display: block;
    }
  }

  .video-hero-slideshow__placeholder {
    width: 100%;
    height: 100%;
    background: var(--color-background);
  }

  .video-hero-slideshow__placeholder svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Slide text content — positioned over the video */
  .video-hero-slideshow__slide-content {
    position: relative;
    z-index: 1;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: center;
    padding: 0 clamp(1.5rem, 4vw, 4rem);
    padding-bottom: clamp(4.5rem, 8vw, 7rem);
  }

  .video-hero-slideshow__slide-inner {
    width: 100%;
    max-width: 700px;
    margin: 0 auto;
  }

  /* Typography */
  .video-hero-slideshow__subheading {
    font-family: var(--font-body--family);
    font-size: clamp(0.75rem, 1.2vw, 1rem);
    font-weight: 400;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.85);
    margin: 0 0 0.75rem;
    line-height: 1.3;
  }

  .video-hero-slideshow__heading {
    font-family: var(--font-heading--family);
    font-size: clamp(2rem, 5.5vw, 4.5rem);
    font-weight: var(--font-heading--weight, 400);
    line-height: 1.05;
    color: #fff;
    margin: 0 0 1.5rem;
    text-transform: none;
    letter-spacing: -0.01em;
  }

  /* Buttons */
  .video-hero-slideshow__buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }

  .video-hero-slideshow__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.875rem 2rem;
    font-family: var(--font-body--family);
    font-size: clamp(0.75rem, 1vw, 0.875rem);
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease;
    cursor: pointer;
    line-height: 1;
    white-space: nowrap;
  }

  .video-hero-slideshow__button--primary {
    background-color: #fff;
    color: #1a1a1a;
    border: 1px solid #fff;
  }

  .video-hero-slideshow__button--primary:hover {
    background-color: transparent;
    color: #fff;
  }

  .video-hero-slideshow__button--secondary {
    background-color: transparent;
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.6);
  }

  .video-hero-slideshow__button--secondary:hover {
    background-color: #fff;
    color: #1a1a1a;
    border-color: #fff;
  }

  /* Arrow Navigation — inline at bottom within controls */
  .video-hero-slideshow__arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.7);
    cursor: pointer;
    transition: color 0.3s var(--animation-timing-hover, ease);
    padding: 0;
    flex-shrink: 0;
  }

  .video-hero-slideshow__arrow:hover {
    color: #fff;
  }

  /* Controls wrapper: Prev | Dots | Pause | Next */
  .video-hero-slideshow__controls {
    position: absolute;
    bottom: clamp(1.5rem, 4vw, 3rem);
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  /* Dot Navigation */
  .video-hero-slideshow__dots {
    display: flex;
    justify-content: center;
    gap: 8px;
  }

  /* Visually hidden for live region */
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .video-hero-slideshow__dot {
    width: 40px;
    height: 3px;
    background: rgba(255, 255, 255, 0.35);
    border: none;
    padding: 0;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    border-radius: 2px;
    transition: background 0.3s ease;
  }

  .video-hero-slideshow__dot:hover {
    background: rgba(255, 255, 255, 0.55);
  }

  .video-hero-slideshow__dot-progress {
    position: absolute;
    top: 0;
    left: 0;
    width: 0;
    height: 100%;
    background: #fff;
    border-radius: 2px;
  }

  .video-hero-slideshow__dot--active {
    background: rgba(255, 255, 255, 0.35);
  }

  @keyframes dotProgress {
    from { width: 0; }
    to { width: 100%; }
  }

  /* Mobile Adjustments */
  @media screen and (max-width: 749px) {
    .video-hero-slideshow {
      height: 85svh;
      min-height: 450px;
      max-height: 800px;
    }

    .video-hero-slideshow__slide-content {
      padding: 0 1.25rem;
      padding-bottom: 4rem;
    }

    .video-hero-slideshow__heading {
      font-size: clamp(1.75rem, 8vw, 2.75rem);
      margin-bottom: 1.25rem;
    }

    .video-hero-slideshow__button {
      padding: 0.75rem 1.5rem;
      font-size: 0.7rem;
    }

    .video-hero-slideshow__dot {
      width: 28px;
    }

    .video-hero-slideshow__arrow {
      width: 32px;
      height: 32px;
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .video-hero-slideshow__slide {
      transition: none;
    }

    .video-hero-slideshow__dot-progress {
      animation: none;
    }

    .video-hero-slideshow__dot--active .video-hero-slideshow__dot-progress {
      width: 100%;
    }

    .video-hero-slideshow__video {
      animation: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Video hero slideshow",
  "tag": "section",
  "class": "video-hero-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "checkbox",
      "id": "show_overlay",
      "label": "Show overlay",
      "default": true
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "select",
      "id": "overlay_direction",
      "label": "Gradient direction",
      "options": [
        { "value": "to top", "label": "Bottom to top" },
        { "value": "to bottom", "label": "Top to bottom" },
        { "value": "to top left", "label": "Bottom-right to top-left" }
      ],
      "default": "to top"
    },
    {
      "type": "header",
      "content": "Autoplay"
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Fallback seconds per slide",
      "info": "Used when video duration can't be detected.",
      "min": 3,
      "max": 30,
      "step": 1,
      "unit": "s",
      "default": 10
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "limit": 6,
      "settings": [
        {
          "type": "header",
          "content": "Video"
        },
        {
          "type": "text",
          "id": "video_url",
          "label": "Video URL",
          "info": "Paste the full Cloudinary or external video URL for this slide."
        },
        {
          "type": "text",
          "id": "mobile_video_url",
          "label": "Mobile video URL",
          "info": "Optional: different video for mobile. Leave blank to use the desktop video."
        },
        {
          "type": "header",
          "content": "Content"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading",
          "default": "Our pioneering original"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "The Heritage Collection"
        },
        {
          "type": "select",
          "id": "text_alignment",
          "label": "Text alignment",
          "options": [
            { "value": "center", "label": "Center" },
            { "value": "left", "label": "Left" }
          ],
          "default": "center"
        },
        {
          "type": "header",
          "content": "Button 1"
        },
        {
          "type": "text",
          "id": "button_label_1",
          "label": "Button label",
          "default": "Shop the collection"
        },
        {
          "type": "url",
          "id": "button_link_1",
          "label": "Button link"
        },
        {
          "type": "select",
          "id": "button_style_1",
          "label": "Button style",
          "options": [
            { "value": "primary", "label": "Primary (solid)" },
            { "value": "secondary", "label": "Secondary (outline)" }
          ],
          "default": "primary"
        },
        {
          "type": "header",
          "content": "Button 2"
        },
        {
          "type": "text",
          "id": "button_label_2",
          "label": "Button label"
        },
        {
          "type": "url",
          "id": "button_link_2",
          "label": "Button link"
        },
        {
          "type": "select",
          "id": "button_style_2",
          "label": "Button style",
          "options": [
            { "value": "primary", "label": "Primary (solid)" },
            { "value": "secondary", "label": "Secondary (outline)" }
          ],
          "default": "secondary"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Video hero slideshow",
      "category": "Banners",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "subheading": "Our pioneering original",
            "heading": "The Heritage Collection",
            "button_label_1": "Shop the collection",
            "button_style_1": "primary"
          }
        },
        {
          "type": "slide",
          "settings": {
            "subheading": "Timeless vintage meets the big sky",
            "heading": "The Drover",
            "button_label_1": "Shop men's & kids",
            "button_style_1": "primary",
            "button_label_2": "Accessories & more",
            "button_style_2": "secondary"
          }
        },
        {
          "type": "slide",
          "settings": {
            "subheading": "Redefining modern essentials",
            "heading": "The New Collection",
            "button_label_1": "Discover now",
            "button_style_1": "primary"
          }
        }
      ]
    }
  ]
}
{% endschema %}
